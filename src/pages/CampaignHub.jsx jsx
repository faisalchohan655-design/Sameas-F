import React, { useState, useEffect, useMemo } from 'react';
import { useApp } from '../context/AppContext';
import * as Lucide from 'lucide-react';
import * as XLSX from 'xlsx';

const CampaignHub = () => {
  const { leads, fetchLeads, showToast } = useApp();
  const [selected, setSelected] = useState([]);
  const [message, setMessage] = useState('');
  const [subject, setSubject] = useState('');
  const [channel, setChannel] = useState('whatsapp');
  const [selectedTemplate, setSelectedTemplate] = useState('');
  const [search, setSearch] = useState('');
  const [statusFilter, setStatusFilter] = useState('');

  const templates = {
    welcome: {
      label: 'Welcome',
      subject: 'Welcome to {{company}}!',
      message: `Hi {{name}},\n\nWelcome to {{company}}! We're excited to have you on board.\n\nBest regards,\nThe Team`
    },
    followup: {
      label: 'Follow-up',
      subject: 'Following up with {{company}}',
      message: `Hi {{name}},\n\nI wanted to follow up on our recent conversation. Do you have any questions?\n\nBest,\nThe Team`
    },
    proposal: {
      label: 'Proposal',
      subject: 'Proposal for {{company}}',
      message: `Hi {{name}},\n\nHere's the proposal we discussed for {{company}}. Let me know your thoughts.\n\nBest,\nThe Team`
    },
    closing: {
      label: 'Closing',
      subject: 'Closing with {{company}}',
      message: `Hi {{name}},\n\nI'd love to finalize our agreement with {{company}}. When are you available?\n\nBest,\nThe Team`
    },
    newsletter: {
      label: 'Newsletter',
      subject: 'Monthly Newsletter',
      message: `Hi {{name}},\n\nHere's our latest newsletter. We hope you find it valuable!\n\nBest,\nThe Team`
    }
  };

  useEffect(() => { fetchLeads(); }, []);

  // ============ FILTER LEADS ============
  const filteredLeads = useMemo(() => {
    let result = leads;
    if (search) {
      const s = search.toLowerCase();
      result = result.filter(l => 
        l.name?.toLowerCase().includes(s) || 
        l.email?.toLowerCase().includes(s) ||
        l.company?.toLowerCase().includes(s) ||
        l.phone?.includes(s)
      );
    }
    if (statusFilter) {
      result = result.filter(l => l.status === statusFilter);
    }
    return result;
  }, [leads, search, statusFilter]);

  // ============ SELECTION FUNCTIONS ============
  const selectAll = () => {
    if (selected.length === filteredLeads.length) {
      setSelected([]);
    } else {
      setSelected(filteredLeads.map(l => l._id));
    }
  };

  const selectNone = () => {
    setSelected([]);
  };

  const selectOne = (id) => {
    if (selected.includes(id)) {
      setSelected(selected.filter(s => s !== id));
    } else {
      setSelected([...selected, id]);
    }
  };

  const selectSingle = (id) => {
    // Select only this lead (replace all)
    setSelected([id]);
  };

  // ============ TEMPLATE ============
  const applyTemplate = (key) => {
    const t = templates[key];
    if (t) {
      setSelectedTemplate(key);
      setSubject(t.subject);
      setMessage(t.message);
    }
  };

  // ============ PERSONALIZE ============
  const personalizeMessage = (lead, msg) => {
    return msg
      .replace(/{{name}}/g, lead.name || 'Customer')
      .replace(/{{company}}/g, lead.company || 'your company')
      .replace(/{{industry}}/g, lead.industry || 'industry')
      .replace(/{{rating}}/g, lead.rating || 'N/A');
  };

  // ============ SEND FUNCTIONS ============
  const sendWhatsApp = (lead) => {
    const phone = lead.phone || lead.whatsapp || '';
    if (!phone) {
      showToast(`No phone number for ${lead.name}`, 'error');
      return;
    }
    const personalizedMsg = personalizeMessage(lead, message);
    const url = `https://wa.me/${phone.replace(/[^0-9]/g, '')}?text=${encodeURIComponent(personalizedMsg)}`;
    window.open(url, '_blank');
    showToast(`Opening WhatsApp for ${lead.name}`);
  };

  const sendEmail = (lead) => {
    const email = lead.email || '';
    if (!email) {
      showToast(`No email for ${lead.name}`, 'error');
      return;
    }
    const personalizedMsg = personalizeMessage(lead, message);
    const personalizedSubject = personalizeMessage(lead, subject);
    const url = `mailto:${email}?subject=${encodeURIComponent(personalizedSubject)}&body=${encodeURIComponent(personalizedMsg)}`;
    window.open(url, '_blank');
    showToast(`Opening email for ${lead.name}`);
  };

  const sendToAll = () => {
    if (!selected.length) { showToast('Select leads first', 'error'); return; }
    if (!message) { showToast('Enter a message', 'error'); return; }

    const selectedLeads = leads.filter(l => selected.includes(l._id));
    
    if (selectedLeads.length > 10) {
      if (!confirm(`Send to ${selectedLeads.length} leads? This will open multiple tabs.`)) return;
    }

    if (channel === 'whatsapp') {
      selectedLeads.forEach((lead, index) => {
        setTimeout(() => sendWhatsApp(lead), index * 500);
      });
      showToast(`Opening WhatsApp for ${selectedLeads.length} leads`);
    } else {
      selectedLeads.forEach((lead, index) => {
        setTimeout(() => sendEmail(lead), index * 500);
      });
      showToast(`Opening email for ${selectedLeads.length} leads`);
    }
  };

  // ============ COPY ============
  const copyToClipboard = (lead) => {
    const personalizedMsg = personalizeMessage(lead, message);
    navigator.clipboard.writeText(personalizedMsg);
    showToast('Message copied!');
  };

  // ============ EXPORT ============
  const exportExcel = () => {
    if (!selected.length) { showToast('Select leads first', 'error'); return; }
    const selectedLeads = leads.filter(l => selected.includes(l._id));
    const data = selectedLeads.map(l => ({
      Name: l.name || '',
      Email: l.email || '',
      Company: l.company || '',
      Phone: l.phone || '',
      Website: l.website || '',
      Location: l.location || '',
      Status: l.status || 'new',
      'AI Score': l.aiScore || 0,
      'Created At': new Date(l.createdAt).toLocaleDateString()
    }));
    const wb = XLSX.utils.book_new();
    const ws = XLSX.utils.json_to_sheet(data);
    XLSX.utils.book_append_sheet(wb, ws, 'Selected Leads');
    XLSX.writeFile(wb, `selected_leads_${Date.now()}.xlsx`);
    showToast(`Exported ${selectedLeads.length} leads to Excel`);
  };

  const exportCSV = () => {
    if (!selected.length) { showToast('Select leads first', 'error'); return; }
    const selectedLeads = leads.filter(l => selected.includes(l._id));
    const headers = ['Name', 'Email', 'Company', 'Phone', 'Website', 'Location', 'Status', 'AI Score'];
    const rows = selectedLeads.map(l => [
      l.name || '', l.email || '', l.company || '', l.phone || '',
      l.website || '', l.location || '', l.status || 'new', l.aiScore || 0
    ]);
    const csv = [headers.join(','), ...rows.map(r => r.join(','))].join('\n');
    const blob = new Blob([csv], { type: 'text/csv' });
    const url = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `selected_leads_${Date.now()}.csv`;
    a.click();
    showToast(`Exported ${selectedLeads.length} leads to CSV`);
  };

  // ============ STATS ============
  const stats = {
    total: leads.length,
    filtered: filteredLeads.length,
    selected: selected.length,
    contacted: leads.filter(l => l.status === 'contacted').length,
    qualified: leads.filter(l => l.status === 'qualified').length
  };

  // ============ RENDER ============
  return (
    <div className="p-6 max-w-7xl mx-auto">
      {/* Header */}
      <div className="flex items-center justify-between mb-6">
        <h1 className="text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-500 to-pink-500">
          Campaign Hub
        </h1>
        <div className="flex items-center gap-2 text-sm text-gray-400">
          <span className="px-3 py-1 rounded-full bg-white/5 border border-white/10">
            {stats.selected} / {stats.filtered} selected
          </span>
        </div>
      </div>

      {/* Stats Cards */}
      <div className="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-6">
        <div className="bg-white/5 p-3 rounded-xl border border-white/10">
          <div className="text-xs text-gray-400">Total</div>
          <div className="text-lg font-bold">{stats.total}</div>
        </div>
        <div className="bg-white/5 p-3 rounded-xl border border-white/10">
          <div className="text-xs text-gray-400">Filtered</div>
          <div className="text-lg font-bold text-blue-400">{stats.filtered}</div>
        </div>
        <div className="bg-white/5 p-3 rounded-xl border border-white/10 border-purple-500/30">
          <div className="text-xs text-gray-400">Selected</div>
          <div className="text-lg font-bold text-purple-400">{stats.selected}</div>
        </div>
        <div className="bg-white/5 p-3 rounded-xl border border-white/10">
          <div className="text-xs text-gray-400">Contacted</div>
          <div className="text-lg font-bold text-yellow-400">{stats.contacted}</div>
        </div>
        <div className="bg-white/5 p-3 rounded-xl border border-white/10">
          <div className="text-xs text-gray-400">Qualified</div>
          <div className="text-lg font-bold text-green-400">{stats.qualified}</div>
        </div>
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {/* ============ LEAD SELECTION ============ */}
        <div className="bg-white/5 p-5 rounded-2xl border border-white/10">
          <div className="flex items-center justify-between mb-4">
            <h3 className="font-medium">Select Leads</h3>
            <div className="flex gap-2">
              <button 
                onClick={selectAll}
                className="px-3 py-1 text-xs rounded-lg bg-purple-500/20 text-purple-400 hover:bg-purple-500/30 transition">
                {selected.length === filteredLeads.length ? 'Deselect All' : 'Select All'}
              </button>
              <button 
                onClick={selectNone}
                className="px-3 py-1 text-xs rounded-lg bg-white/5 hover:bg-white/10 transition text-gray-400">
                Clear
              </button>
            </div>
          </div>

          {/* Search & Filter */}
          <div className="flex gap-2 mb-3">
            <div className="flex-1 relative">
              <Lucide.Search size={14} className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500" />
              <input 
                type="text" 
                placeholder="Search leads..." 
                value={search} 
                onChange={(e) => setSearch(e.target.value)}
                className="w-full pl-8 pr-3 py-1.5 text-sm rounded-xl bg-white/5 border border-white/10 focus:border-purple-500/50 outline-none" 
              />
            </div>
            <select 
              value={statusFilter} 
              onChange={(e) => setStatusFilter(e.target.value)}
              className="px-3 py-1.5 text-sm rounded-xl bg-white/5 border border-white/10 outline-none focus:border-purple-500/50">
              <option value="">All Status</option>
              <option value="new">New</option>
              <option value="contacted">Contacted</option>
              <option value="qualified">Qualified</option>
              <option value="proposal">Proposal</option>
              <option value="closed">Closed</option>
            </select>
          </div>

          {/* Leads List */}
          <div className="max-h-[420px] overflow-y-auto space-y-1.5 pr-1">
            {filteredLeads.length === 0 ? (
              <div className="text-center py-12 text-gray-400 text-sm">
                <Lucide.Users size={32} className="mx-auto mb-2 opacity-50" />
                No leads found
              </div>
            ) : (
              filteredLeads.map((lead) => {
                const isSelected = selected.includes(lead._id);
                return (
                  <div 
                    key={lead._id} 
                    className={`group flex items-center gap-3 p-2.5 rounded-xl cursor-pointer transition-all duration-200 ${
                      isSelected 
                        ? 'bg-purple-500/20 border border-purple-500/30 shadow-lg shadow-purple-500/10' 
                        : 'hover:bg-white/5 border border-transparent'
                    }`}
                    onClick={() => selectOne(lead._id)}>
                    
                    <input 
                      type="checkbox" 
                      checked={isSelected} 
                      onChange={() => selectOne(lead._id)}
                      className="w-4 h-4 rounded border-white/20 bg-transparent checked:bg-purple-500" 
                      onClick={(e) => e.stopPropagation()}
                    />
                    
                    <div className="flex-1 min-w-0">
                      <div className="flex items-center gap-2">
                        <span className="text-sm font-medium truncate">{lead.name || 'N/A'}</span>
                        {lead.aiScore >= 80 && <span className="text-xs text-purple-400">🔥</span>}
                        {lead.aiScore >= 60 && lead.aiScore < 80 && <span className="text-xs text-blue-400">🔵</span>}
                      </div>
                      <div className="flex items-center gap-2 text-xs text-gray-400 truncate">
                        {lead.email && <span>{lead.email}</span>}
                        {lead.email && lead.phone && <span>•</span>}
                        {lead.phone && <span>{lead.phone}</span>}
                      </div>
                    </div>

                    <div className="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition">
                      <button 
                        onClick={(e) => { e.stopPropagation(); selectSingle(lead._id); }}
                        className="p-1 rounded hover:bg-white/10 text-gray-400 hover:text-white transition"
                        title="Select only this">
                        <Lucide.Focus size={14} />
                      </button>
                      {lead.phone && channel === 'whatsapp' && (
                        <button 
                          onClick={(e) => { e.stopPropagation(); sendWhatsApp(lead); }}
                          className="p-1 rounded hover:bg-green-500/20 text-green-400 transition"
                          title="Send WhatsApp">
                          <Lucide.MessageCircle size={14} />
                        </button>
                      )}
                      {lead.email && channel === 'email' && (
                        <button 
                          onClick={(e) => { e.stopPropagation(); sendEmail(lead); }}
                          className="p-1 rounded hover:bg-blue-500/20 text-blue-400 transition"
                          title="Send Email">
                          <Lucide.Mail size={14} />
                        </button>
                      )}
                      <button 
                        onClick={(e) => { e.stopPropagation(); copyToClipboard(lead); }}
                        className="p-1 rounded hover:bg-white/10 text-gray-400 hover:text-white transition"
                        title="Copy message">
                        <Lucide.Copy size={14} />
                      </button>
                    </div>

                    <span className={`px-2 py-0.5 rounded-full text-[10px] ${
                      lead.status === 'new' ? 'bg-blue-500/20 text-blue-400' :
                      lead.status === 'contacted' ? 'bg-yellow-500/20 text-yellow-400' :
                      lead.status === 'qualified' ? 'bg-green-500/20 text-green-400' :
                      lead.status === 'proposal' ? 'bg-purple-500/20 text-purple-400' :
                      'bg-gray-500/20 text-gray-400'
                    }`}>
                      {lead.status || 'new'}
                    </span>
                  </div>
                );
              })
            )}
          </div>

          {/* Selection Footer */}
          {selected.length > 0 && (
            <div className="mt-3 pt-3 border-t border-white/5 flex items-center justify-between">
              <span className="text-xs text-gray-400">
                {selected.length} lead{selected.length > 1 ? 's' : ''} selected
              </span>
              <div className="flex gap-2">
                <button 
                  onClick={exportExcel}
                  className="px-3 py-1.5 text-xs rounded-lg bg-green-500/20 text-green-400 hover:bg-green-500/30 transition flex items-center gap-1">
                  <Lucide.FileSpreadsheet size={12} /> Excel
                </button>
                <button 
                  onClick={exportCSV}
                  className="px-3 py-1.5 text-xs rounded-lg bg-blue-500/20 text-blue-400 hover:bg-blue-500/30 transition flex items-center gap-1">
                  <Lucide.FileText size={12} /> CSV
                </button>
                <button 
                  onClick={() => { if (confirm('Clear selection?')) selectNone(); }}
                  className="px-3 py-1.5 text-xs rounded-lg bg-red-500/20 text-red-400 hover:bg-red-500/30 transition flex items-center gap-1">
                  <Lucide.X size={12} /> Clear
                </button>
              </div>
            </div>
          )}
        </div>

        {/* ============ COMPOSER ============ */}
        <div className="bg-white/5 p-5 rounded-2xl border border-white/10">
          <h3 className="font-medium mb-4">Composer</h3>
          
          {/* Channel Selection */}
          <div className="flex gap-2 mb-3">
            <button 
              onClick={() => setChannel('whatsapp')} 
              className={`flex-1 py-2 rounded-xl text-sm transition flex items-center justify-center gap-2 ${
                channel === 'whatsapp' 
                  ? 'bg-gradient-to-r from-purple-500 to-pink-500 text-white' 
                  : 'bg-white/5 hover:bg-white/10'
              }`}>
              <Lucide.MessageCircle size={16} /> WhatsApp
            </button>
            <button 
              onClick={() => setChannel('email')} 
              className={`flex-1 py-2 rounded-xl text-sm transition flex items-center justify-center gap-2 ${
                channel === 'email' 
                  ? 'bg-gradient-to-r from-purple-500 to-pink-500 text-white' 
                  : 'bg-white/5 hover:bg-white/10'
              }`}>
              <Lucide.Mail size={16} /> Email
            </button>
          </div>

          {/* Templates */}
          <select 
            value={selectedTemplate} 
            onChange={(e) => applyTemplate(e.target.value)}
            className="w-full px-3 py-2 rounded-xl bg-white/5 border border-white/10 outline-none text-sm mb-3 focus:border-purple-500/50">
            <option value="">📝 Select Template</option>
            {Object.entries(templates).map(([key, t]) => (
              <option key={key} value={key}>📄 {t.label}</option>
            ))}
          </select>

          {/* Subject (for email) */}
          {channel === 'email' && (
            <input 
              type="text" 
              value={subject} 
              onChange={(e) => setSubject(e.target.value)} 
              placeholder="Subject"
              className="w-full px-3 py-2 rounded-xl bg-white/5 border border-white/10 focus:border-purple-500/50 outline-none text-sm mb-3" 
            />
          )}

          {/* Message */}
          <textarea 
            rows={6} 
            value={message} 
            onChange={(e) => setMessage(e.target.value)}
            className="w-full px-3 py-2 rounded-xl bg-white/5 border border-white/10 outline-none resize-none text-sm focus:border-purple-500/50"
            placeholder={`Type your ${channel} message...`} />

          {/* Variables */}
          <div className="flex flex-wrap gap-1 mt-2">
            <span className="text-[10px] text-gray-500">Variables:</span>
            {['{{name}}', '{{company}}', '{{industry}}', '{{rating}}'].map(v => (
              <button 
                key={v}
                onClick={() => setMessage(message + v)}
                className="text-[10px] px-2 py-0.5 rounded bg-white/5 hover:bg-white/10 transition text-purple-400">
                {v}
              </button>
            ))}
          </div>

          {/* Action Buttons */}
          <div className="grid grid-cols-2 gap-2 mt-3">
            <button 
              onClick={sendToAll} 
              disabled={!selected.length || !message}
              className="py-2 rounded-xl bg-gradient-to-r from-purple-500 to-pink-500 text-white font-medium hover:opacity-90 transition disabled:opacity-50 flex items-center justify-center gap-2">
              <Lucide.Send size={16} />
              Send to All ({selected.length})
            </button>
            <button 
              onClick={() => {
                if (!selected.length) { showToast('Select a lead first', 'error'); return; }
                if (!message) { showToast('Enter a message', 'error'); return; }
                const lead = leads.find(l => l._id === selected[0]);
                if (channel === 'whatsapp') sendWhatsApp(lead);
                else sendEmail(lead);
              }}
              disabled={!selected.length || !message}
              className="py-2 rounded-xl bg-white/5 hover:bg-white/10 transition font-medium disabled:opacity-50 flex items-center justify-center gap-2">
              <Lucide.User size={16} />
              Send to First
            </button>
          </div>

          {/* Quick Actions */}
          <div className="grid grid-cols-3 gap-2 mt-2">
            <button 
              onClick={() => {
                if (!selected.length) { showToast('Select a lead first', 'error'); return; }
                const lead = leads.find(l => l._id === selected[0]);
                copyToClipboard(lead);
              }}
              disabled={!selected.length || !message}
              className="py-1.5 rounded-xl bg-white/5 hover:bg-white/10 transition text-xs disabled:opacity-50 flex items-center justify-center gap-1">
              <Lucide.Copy size={12} /> Copy
            </button>
            <button 
              onClick={() => {
                setMessage('');
                setSubject('');
                setSelectedTemplate('');
                showToast('Cleared', 'info');
              }}
              className="py-1.5 rounded-xl bg-white/5 hover:bg-white/10 transition text-xs flex items-center justify-center gap-1">
              <Lucide.X size={12} /> Clear
            </button>
            <button 
              onClick={() => {
                const lead = leads.find(l => l._id === selected[0]);
                if (lead) {
                  const phone = lead.phone || lead.email;
                  if (phone) {
                    navigator.clipboard.writeText(phone);
                    showToast('Contact copied!');
                  }
                }
              }}
              disabled={!selected.length}
              className="py-1.5 rounded-xl bg-white/5 hover:bg-white/10 transition text-xs disabled:opacity-50 flex items-center justify-center gap-1">
              <Lucide.Phone size={12} /> Contact
            </button>
          </div>

          {/* Info */}
          <div className="mt-3 text-xs text-center text-gray-500 border-t border-white/5 pt-3">
            {channel === 'whatsapp' ? (
              <>📱 Opens WhatsApp web/app with pre-filled message</>
            ) : (
              <>📧 Opens default email client with pre-filled subject & body</>
            )}
          </div>
        </div>
      </div>
    </div>
  );
};

export default CampaignHub;
