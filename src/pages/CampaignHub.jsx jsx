import React, { useState, useEffect } from 'react';
import { useApp } from '../App';
import * as Lucide from 'lucide-react';

const CampaignHub = () => {
  const { leads, fetchLeads, showToast } = useApp();
  const [selectedLeads, setSelectedLeads] = useState([]);
  const [message, setMessage] = useState('');
  const [subject, setSubject] = useState('');
  const [channel, setChannel] = useState('whatsapp');
  const [template, setTemplate] = useState('');

  const templates = {
    welcome: {
      label: 'Welcome',
      subject: 'Welcome to {{company}}!',
      message: 'Hi {{name}},\n\nWelcome to {{company}}! We\'re excited to have you on board.\n\nBest regards,\nThe Team'
    },
    followup: {
      label: 'Follow-up',
      subject: 'Following up with {{company}}',
      message: 'Hi {{name}},\n\nI wanted to follow up on our recent conversation. Do you have any questions?\n\nBest,\nThe Team'
    },
    proposal: {
      label: 'Proposal',
      subject: 'Proposal for {{company}}',
      message: 'Hi {{name}},\n\nHere\'s the proposal we discussed for {{company}}. Let me know your thoughts.\n\nBest,\nThe Team'
    },
    closing: {
      label: 'Closing',
      subject: 'Closing the deal with {{company}}',
      message: 'Hi {{name}},\n\nI\'d love to finalize our agreement with {{company}}. When are you available to chat?\n\nBest,\nThe Team'
    },
    newsletter: {
      label: 'Newsletter',
      subject: 'Monthly Newsletter for {{company}}',
      message: 'Hi {{name}},\n\nHere\'s our latest newsletter. We hope you find it valuable!\n\nBest,\nThe Team'
    }
  };

  const applyTemplate = (key) => {
    const t = templates[key];
    if (t) {
      setTemplate(key);
      setSubject(t.subject);
      setMessage(t.message);
    }
  };

  const handleSend = async () => {
    if (selectedLeads.length === 0) {
      showToast('Please select at least one lead', 'error');
      return;
    }
    if (!message) {
      showToast('Please enter a message', 'error');
      return;
    }

    try {
      const endpoint = channel === 'whatsapp' ? '/campaign/send/whatsapp' : '/campaign/send/email';
      const payload = {
        leadIds: selectedLeads,
        message,
        ...(channel === 'email' && { subject }),
        template,
      };
      await API.post(endpoint, payload);
      showToast(`Campaign sent to ${selectedLeads.length} leads via ${channel}`);
      setSelectedLeads([]);
      setMessage('');
      setSubject('');
    } catch (e) {
      showToast(e.response?.data?.message || 'Failed to send campaign', 'error');
    }
  };

  const toggleLead = (id) => {
    if (selectedLeads.includes(id)) setSelectedLeads(selectedLeads.filter(l => l !== id));
    else setSelectedLeads([...selectedLeads, id]);
  };

  useEffect(() => { fetchLeads(); }, []);

  return (
    <div className="p-6 md:p-8 max-w-7xl mx-auto">
      <h1 className="text-2xl font-bold gradient-text mb-6">Campaign Hub</h1>

      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {/* Lead Selection */}
        <div className="lg:col-span-2 glass p-5 rounded-2xl border border-white/5">
          <div className="flex items-center justify-between mb-4">
            <h3 className="font-medium">Select Leads</h3>
            <span className="text-xs text-gray-400">{selectedLeads.length} selected</span>
          </div>
          <div className="max-h-96 overflow-y-auto space-y-2">
            {leads.length === 0 ? (
              <div className="text-center py-8">
                <div className="w-16 h-16 mx-auto rounded-2xl glass flex items-center justify-center mb-3">
                  <Lucide.Users size={24} className="text-gray-500" />
                </div>
                <p className="text-sm text-gray-400">No leads available</p>
              </div>
            ) : (
              leads.map((lead) => (
                <div
                  key={lead._id}
                  className={`flex items-center gap-3 p-3 rounded-xl transition cursor-pointer ${selectedLeads.includes(lead._id) ? 'glass border border-purple-500/30' : 'hover:bg-white/5'
                    }`}
                  onClick={() => toggleLead(lead._id)}
                >
                  <input
                    type="checkbox"
                    checked={selectedLeads.includes(lead._id)}
                    onChange={() => {}}
                    className="rounded border-white/10 bg-transparent"
                  />
                  <div className="flex-1 min-w-0">
                    <div className="font-medium text-sm">{lead.name || 'N/A'}</div>
                    <div className="text-xs text-gray-400">{lead.email || lead.phone || 'No contact'}</div>
                  </div>
                  {lead.aiScore >= 80 ? (
                    <span className="text-xs text-purple-400">🔥 Hot</span>
                  ) : lead.aiScore >= 60 ? (
                    <span className="text-xs text-blue-400">🔵 Warm</span>
                  ) : (
                    <span className="text-xs text-gray-400">⚪ Cold</span>
                  )}
                </div>
              ))
            )}
          </div>
        </div>

        {/* Campaign Composer */}
        <div className="glass p-5 rounded-2xl border border-white/5">
          <h3 className="font-medium mb-4">Composer</h3>

          <div className="flex gap-2 mb-3">
            <button
              onClick={() => setChannel('whatsapp')}
              className={`flex-1 px-3 py-2 rounded-xl text-xs font-medium transition ${channel === 'whatsapp' ? 'gradient-bg text-white' : 'glass-dark text-gray-400 hover:text-white'
                }`}
            >
              <Lucide.MessageCircle size={14} className="inline mr-1" /> WhatsApp
            </button>
            <button
              onClick={() => setChannel('email')}
              className={`flex-1 px-3 py-2 rounded-xl text-xs font-medium transition ${channel === 'email' ? 'gradient-bg text-white' : 'glass-dark text-gray-400 hover:text-white'
                }`}
            >
              <Lucide.Mail size={14} className="inline mr-1" /> Email
            </button>
          </div>

          <div className="space-y-3">
            <div>
              <label className="text-xs text-gray-400 block mb-1">Template</label>
              <select
                value={template}
                onChange={(e) => applyTemplate(e.target.value)}
                className="w-full px-3 py-2 rounded-xl glass-dark border border-white/5 focus:border-purple-500/50 outline-none text-sm"
              >
                <option value="">Custom</option>
                {Object.entries(templates).map(([key, t]) => (
                  <option key={key} value={key}>{t.label}</option>
                ))}
              </select>
            </div>

            {channel === 'email' && (
              <div>
                <label className="text-xs text-gray-400 block mb-1">Subject</label>
                <input
                  type="text"
                  value={subject}
                  onChange={(e) => setSubject(e.target.value)}
                  className="w-full px-3 py-2 rounded-xl glass-dark border border-white/5 focus:border-purple-500/50 outline-none text-sm"
                  placeholder="Email subject..."
                />
              </div>
            )}

            <div>
              <label className="text-xs text-gray-400 block mb-1">Message</label>
              <textarea
                value={message}
                onChange={(e) => setMessage(e.target.value)}
                rows={6}
                className="w-full px-3 py-2 rounded-xl glass-dark border border-white/5 focus:border-purple-500/50 outline-none text-sm resize-none"
                placeholder={`Type your ${channel} message...`}
              />
            </div>

            <button
              onClick={handleSend}
              disabled={selectedLeads.length === 0 || !message}
              className="w-full py-2.5 rounded-xl gradient-bg text-white font-medium hover:opacity-90 transition disabled:opacity-50 flex items-center justify-center gap-2"
            >
              <Lucide.Send size={16} />
              Send to {selectedLeads.length} leads
            </button>

            <div className="text-xs text-gray-500 text-center">
              Variables: {'{{name}}'}, {'{{company}}'}, {'{{industry}}'}, {'{{rating}}'}
            </div>
          </div>
        </div>
      </div>
    </div>
  );
};

export default CampaignHub;
